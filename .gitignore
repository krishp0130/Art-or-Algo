# Kaggle image dataset (~480MB) — use scripts/download_dataset.sh locally
/data/Art/
/data/*.zip
# Train/val views — regenerate with scripts/split_train_eval.py
/data/train/
/data/val/

# Python
.venv/
__pycache__/
*.pyc

# Node (Vue client + Express server)
node_modules/
client/dist/

# OS
.DS_Store

# HCI failure gallery (regenerate with ml/analyze_failures.py)
server/public/failures/*
!server/public/failures/.gitkeep

# Trained weights & run metrics (regenerate with run_train.py / ml.train)
/models/*.pth
/models/metrics.json
