# Kaggle image dataset (~480MB) — use scripts/download_dataset.sh locally
/data/Art/
/data/*.zip
# Train/val views — regenerate with scripts/split_train_eval.py
/data/train/
/data/val/

# Python
.venv/
__pycache__/
*.pyc

# Node (Vue client + Express server)
node_modules/
client/dist/

# OS
.DS_Store

# HCI failure gallery images (large); manifest can be committed for static UI metadata
server/public/failures/*
!server/public/failures/.gitkeep
!server/public/failures/failures.json

# Synced into Vue public/ at build time (optional local copies)
client/public/metrics.json
client/public/failures/*
!client/public/failures/.gitkeep

# Trained weights (metrics.json is safe to commit for static dashboard / Pages)
/models/*.pth
